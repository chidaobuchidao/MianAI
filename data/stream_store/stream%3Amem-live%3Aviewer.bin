8d677aa-bf47-4931-9ce2-4fa8334f2126","type":"compressed"},"obs_mpjb85j9_ae986fc9dd6b":{"observation":{"concepts":[],"confidence":0.3,"facts":[],"files":["E:\\My_Projects\\IntervVault\\mianmiantong-server\\src\\main\\resources\\prompts\\ai_reduce_transform.txt"],"id":"obs_mpjb85j9_ae986fc9dd6b","importance":5,"narrative":"{\"content\":\"дљ†жШѓдЄАдљНе≠¶жЬѓжЦЗе≠ЧзЉЦиЊСпЉМдЄУйЧ®жґИйЩ§AIзФЯжИРжЦЗжЬђзЪДзЧХињєгАВдљ†зЪДиЊУеЗЇењЕй°їеГПзЬЯеЃЮз†Фз©ґиАЕеЖЩеЗЇжЭ•зЪДвАФвАФжЬЙиІВзВєгАБжЬЙиКВе•ПгАБжЬЙеПЦиИНпЉМиАМдЄНжШѓж®°жЭњеМЦгАБжЬЇжҐ∞еМЦзЪД\\\"AIиЕФ\\\"гАВ\\n---SYSTEM---\\n## иІТиЙ≤\\nдљ†жШѓдЄАдљНе≠¶жЬѓжЦЗе≠ЧзЉЦиЊСпЉМдЄУйЧ®жґИйЩ§AIзФЯжИРжЦЗжЬђзЪДзЧХињєгАВиЊУеЗЇењЕй°їж®°дїњзЬЯеЃЮе≠¶иАЕзЪДиЗ™зДґеЖЩдљЬгАВ\\n\\n## е§ДзРЖеОЯеИЩпЉИжМЙдЉШеЕИзЇІжОТеЇПпЉЙ\\n1. **дЉШеЕИе§ДзРЖж†Зж≥®зЙЗжЃµ** вАФ иЛ•дЄЛжЦє\\\"ж†Зж≥®зЙЗжЃµ\\\"еИЧи°®йЭЮз©ЇпЉМињЩдЇЫжШѓжЙЂжППж£АжµЛеЗЇзЪДйЂШй£ОйЩ©еП•е≠РпЉМењЕй°їйАРеП•йТИеѓєжАІжґИйЩ§еЕґж†Зж≥®зЪДйЧЃйҐШпЉИжЬЇжҐ∞ињЮжО•иѓНгАБз©ЇжіЮеЃПе§ІиѓНгАБж®°жЭњеП•еЉПгАБе°ЂеЕЕе•ЧиѓЭз≠ЙпЉЙпЉМеЕґдљЩеЖЕеЃєжМЙ {mode_label} ж≠£еЄЄе§ДзРЖгАВ\\n2. **еИ†йЩ§е°ЂеЕЕзЯ≠иѓ≠** вАФ еОїйЩ§\\\"еАЉеЊЧж≥®жДПзЪДжШѓ\\\"\\\"еЬ®ињЩдЄ™жЧґйЧізВє\\\"\\\"еЬ®е§Іе§ЪжХ∞жГЕеЖµдЄЛ\\\"з≠ЙжЧ†еЃЮиі®дњ°жБѓзЪДжЛРжЭЦиѓНгАВ\\n3. **жЙУз†іеЕђеЉПзїУжЮД** вАФ йБњеЕН\\\"й¶ЦеЕИвА¶еЕґжђ°вА¶жЬАеРО\\\"\\\"дЄАжЦєйЭҐвА¶еП¶дЄАжЦєйЭҐ\\\"з≠ЙжХійљРеѓєдїЧпЉЫдЄНеЉЇеИґвА¶","sessionId":"f8d677aa-bf47-4931-9ce2-4fa8334f2126","subtitle":"{\"content\":\"дљ†жШѓдЄАдљНе≠¶жЬѓжЦЗе≠ЧзЉЦиЊСпЉМдЄУйЧ®жґИйЩ§AIзФЯжИРжЦЗжЬђзЪДзЧХињєгАВдљ†зЪДиЊУеЗЇењЕй°їеГПзЬЯеЃЮз†Фз©ґиАЕеЖЩеЗЇжЭ•зЪДвАФвАФжЬЙиІВзВєгАБжЬЙиКВе•ПгАБжЬЙеПЦиИНпЉМиАМдЄНжШѓж®°жЭњеМЦгАБжЬЇжҐ∞еМЦзЪД\\\"AIиЕФ\\\"гАВ\\n---SYSTEM---\\n## иІТиЙ≤\\nдљ†жШѓдЄАдљНе≠¶жЬѓжЦЗе≠ЧзЉЦиЊСвА¶","timestamp":"2026-05-24T05:01:22.015Z","title":"Write","type":"file_write"},"sessionId":"f8d677aa-bf47-4931-9ce2-4fa8334f2126","type":"compressed"},"obs_mpjb8iyp_870db2e60764":{"observation":{"concepts":[],"confidence":0.3,"facts":[],"files":["E:\\My_Projects\\IntervVault\\mianmiantong-server\\src\\main\\resources\\prompts\\polish_run_task.txt"],"id":"obs_mpjb8iyp_870db2e60764","importance":5,"narrative":"{\"content\":\"дљ†жШѓдЄАдљНй°ґзЇІе≠¶жЬѓеЖЩдљЬзЉЦиЊСпЉМиЊУеЗЇењЕй°їжШѓеПѓзЫіжО•иРљеИ∞иЃЇжЦЗдЄ≠зЪДжЬАзїИжЦЗжЬђгАВдљ†зЪДдїїеК°жШѓжґ¶иЙ≤пЉМдЄНжШѓжАїзїУгАВ\\n---SYSTEM---\\n## иІТиЙ≤\\nй°ґзЇІе≠¶жЬѓеЖЩдљЬзЉЦиЊСгАВдљ†зЪДдїїеК°жШѓжґ¶иЙ≤е≠¶жЬѓжЦЗжЬђвАФвАФдЉШеМЦи°®иЊЊгАБдњЃж≠£йФЩиѓѓгАБеҐЮеЉЇе≠¶жЬѓжАІпЉМдљЖзїЭдЄНеИ†еЗПгАБж¶ВжЛђжИЦеРИеєґеОЯжЦЗеЖЕеЃєгАВ\\n\\n## ж†ЄењГзЇ¶жЭЯпЉИињЭеПНеН≥дЄНеРИж†ЉпЉЙ\\n1. **жЃµиРљзїУжЮДењЕй°їдњЭжМБ** вАФ еОЯжЦЗNжЃµпЉМиЊУеЗЇNжЃµгАВдЄНеРИеєґдЄНжЛЖеИЖпЉМжЃµиРљй°ЇеЇПдЄНеПШгАВ\\n2. **йХњеЇ¶зЇ¶жЭЯ** вАФ жґ¶иЙ≤еРОжАїйХњеЇ¶еЬ®еОЯжЦЗ 90-105% дєЛйЧігАВдЄНеЊЧе§ІеєЕзЉ©зЯ≠гАВ\\n3. **дњЭзХЩжЙАжЬЙжХ∞жНЃ** вАФ жХ∞е≠ЧгАБзЩЊеИЖжѓФгАБжЧ•жЬЯгАБжЬѓиѓ≠гАБеЉХзФ®зЉЦеПЈпЉМдЄАдЄ™дЄНдЄҐгАВ\\n\\n## дїїеК°з±їеЮЛ\\n- иЃЇжЦЗе§ІзЇ≤: йЗНжЮДдЄЇе±ВзЇІжЄЕжЩ∞гАБйАїиЊСйАТињЫзЪДе§ІзЇ≤пЉМдЄНжЙ©еЖЩдЄЇйХњжЃµж≠£жЦЗгАВ\\n- жСШи¶Б: иѓ≠ж∞ФеЃҐиІВеЗЭзїГпЉМз™БеЗЇз†Фз©ґзЫЃзЪД/жЦєж≥Х/зїУжЮЬ/зїУиЃЇгАВ\\n- еЉХи®А: жМЙ\\\"з†Фз©ґиГМжЩѓвЖТйЧЃйҐШжПРеЗЇвЖТеЈ≤жЬЙеЈ•дљЬдЄОдЄНиґ≥вЖТжЬђжЦЗжЦєж°ИвЖТиЃЇжЦЗзїУжЮД\\\"вА¶","sessionId":"f8d677aa-bf47-4931-9ce2-4fa8334f2126","subtitle":"{\"content\":\"дљ†жШѓдЄАдљНй°ґзЇІе≠¶жЬѓеЖЩдљЬзЉЦиЊСпЉМиЊУеЗЇењЕй°їжШѓеПѓзЫіжО•иРљеИ∞иЃЇжЦЗдЄ≠зЪДжЬАзїИжЦЗжЬђгАВдљ†зЪДдїїеК°жШѓжґ¶иЙ≤пЉМдЄНжШѓжАїзїУгАВ\\n---SYSTEM---\\n## иІТиЙ≤\\nй°ґзЇІе≠¶жЬѓеЖЩдљЬзЉЦиЊСгАВдљ†зЪДдїїеК°жШѓжґ¶иЙ≤е≠¶жЬѓжЦЗжЬђвАФвАФдЉШеМЦи°®иЊЊгАБдњЃж≠£йФЩиѓѓгАБеҐЮеЉЇе≠¶жЬѓжАІпЉМдљЖвА¶","timestamp":"2026-05-24T05:01:39.422Z","title":"Write","type":"file_write"},"sessionId":"f8d677aa-bf47-4931-9ce2-4fa8334f2126","type":"compressed"},"obs_mpjb8xkl_7247f291fd07":{"observation":{"concepts":[],"confidence":0.3,"facts":[],"files":["E:\\My_Projects\\IntervVault\\mianmiantong-server\\src\\main\\resources\\prompts\\plagiarism_transform.txt"],"id":"obs_mpjb8xkl_7247f291fd07","importance":5,"narrative":"{\"content\":\"дљ†жШѓдЄАдљНдЄУдЄЪзЪДе≠¶жЬѓжФєеЖЩзЉЦиЊСпЉМжУЕйХњеЬ®дњЭзХЩеОЯжДПдЄОжХ∞жНЃзЪДеЙНжПРдЄЛз≤Њз°ЃиІДйБњйЗНе§Ни°®иЊЊпЉМйЩНдљОжЯ•йЗНзОЗгАВ\\n---SYSTEM---\\n## иІТиЙ≤\\nдЄУдЄЪе≠¶жЬѓжФєеЖЩзЉЦиЊСгАВдљ†зЪДдїїеК°жШѓйАЪињЗеРМдєЙжЫњжНҐгАБеП•еЉПйЗНжЮДгАБйАїиЊСйЗНзїДз≠ЙжЙЛжЃµйЩНдљОжЦЗжЬђйЗНе§НзОЗпЉМеРМжЧґдњЭжМБе≠¶жЬѓиІДиМГеТМеОЯжДПдЄНеПШгАВ\\n\\n## жФєеЖЩдЉШеЕИзЇІ\\n1. **ж†Зж≥®зЙЗжЃµдЉШеЕИ** вАФ иЛ•дЄЛжЦє\\\"ж†Зж≥®зЙЗжЃµ\\\"еИЧи°®йЭЮз©ЇпЉМињЩдЇЫжШѓжЯ•йЗН/AIGCжК•еСКж†ЗиЃ∞зЪДйЂШй£ОйЩ©еЖЕеЃєпЉМ**ењЕй°їйАРжЭ°дЉШеЕИдЄФжЈ±еЇ¶жФєеЖЩ**пЉИжФєеЖЩеєЕеЇ¶дЄНдљОдЇОељУеЙНж®°еЉПйїШиЃ§еєЕеЇ¶пЉЙгАВ\\n2. **йЗНе§НжЇРиІДйБњ** вАФ иЛ•дЄЛжЦє\\\"йЗНе§НжЇРжЦЗжЬђ\\\"йЭЮз©ЇпЉМдЉШеЕИжФєеЖЩдЄОеЕґињЮзї≠йЗНеРИ > 10 е≠ЧзЪДи°®иЊЊгАВ\\n3. **еЕґдљЩеЖЕеЃє** вАФ жМЙељУеЙНеЉЇеЇ¶ж≠£еЄЄе§ДзРЖгАВ\\n\\n## йЩНйЗНжКАж≥Х\\n1. **еРМдєЙжЫњжНҐ**: иѓНиѓ≠зЇІпЉИ\\\"и°®жШО\\\"вЖТ\\\"жШЊз§Ї\\\"гАБ\\\"жШЊиСЧ\\\"вЖТ\\\"жШОжШЊ\\\"гАБ\\\"йЗЗзФ®\\\"вЖТ\\\"ињРзФ®\\\"пЉЙпЉЫжИРиѓ≠/еЫЫе≠ЧиѓНпЉИ\\\"жБѓжБѓзЫЄеЕ≥\\вА¶","sessionId":"f8d677aa-bf47-4931-9ce2-4fa8334f2126","subtitle":"{\"content\":\"дљ†жШѓдЄАдљНдЄУдЄЪзЪДе≠¶жЬѓжФєеЖЩзЉЦиЊСпЉМжУЕйХњеЬ®дњЭзХЩеОЯжДПдЄОжХ∞жНЃзЪДеЙНжПРдЄЛз≤Њз°ЃиІДйБњйЗНе§Ни°®иЊЊпЉМйЩНдљОжЯ•йЗНзОЗгАВ\\n---SYSTEM---\\n## иІТиЙ≤\\nдЄУдЄЪе≠¶жЬѓжФєеЖЩзЉЦиЊСгАВдљ†зЪДдїїеК°жШѓйАЪињЗеРМдєЙжЫњжНҐгАБеП•еЉПйЗНжЮДгАБйАїиЊСйЗНзїДз≠ЙжЙЛжЃµйЩНдљОжЦЗжЬђйЗНе§НзОЗпЉМвА¶","timestamp":"2026-05-24T05:01:58.354Z","title":"Write","type":"file_write"},"sessionId":"f8d677aa-bf47-4931-9ce2-4fa8334f2126","type":"compressed"},"obs_mpjbag1o_a9346751b8e6":{"observation":{"concepts":[],"confidence":0.3,"facts":[],"files":[],"id":"obs_mpjbag1o_a9346751b8e6","importance":5,"narrative":"{\"command\":\"cd \\\"E:\\\\My_Projects\\\\IntervVault\\\\mianmiantong-server\\\" && mvn compiler:compile -q 2>&1 && echo \\\"JAVA OK\\\" && echo \\\"---\\\" && for f in prompts/ai_reduce_transform.txt prompts/polish_run_task.txt prompts/plagiarism_transform.txt; do echo \\\"$f: $(wc -c < src/main/resources/$f) chars, vars present:\\\"; grep -oP '\\\\{[a-z_]+\\\\}' src/main/resources/$f | sort -u | tr '\\\\n' ' '; echo; done\",вА¶","sessionId":"f8d677aa-bf47-4931-9ce2-4fa8334f2126","subtitle":"{\"command