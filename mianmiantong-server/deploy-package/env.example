# 面面通后端 — 生产环境变量
# 复制为 .env 并填入真实值

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=你的MySQL密码
DB_NAME=ai-interview

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=你的JWT密钥（随机字符串不要泄露）

# AI Provider
DEEPSEEK_API_KEY=你的DeepSeek_API_Key

# 阿里云文档智能（简历解析）
ALIBABA_CLOUD_ACCESS_KEY_ID=你的阿里云AccessKey
ALIBABA_CLOUD_ACCESS_KEY_SECRET=你的阿里云AccessKeySecret

# 微信小程序
WECHAT_APP_ID=你的微信小程序AppID
WECHAT_APP_SECRET=你的微信小程序AppSecret

# 服务端口
APP_PORT=8080
